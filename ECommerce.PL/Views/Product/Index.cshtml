@{
    ViewData["Title"] = "All";
}
@model IEnumerable<ProductReadMV>

<h1>All Products</h1>



@* <a asp-controller="Product" asp-action="Create" class="my-2 btn btn-primary"> Add New Product </a> *@

<a id="ClearFilter" class="my-2 ms-2 btn btn-danger"> Clear Filter </a>
<div class="mb-3">
    <label for="Category" class="form-label">Category</label>
    <select id="Category" asp-items="@ViewBag.Categories" class="form-control">
        <option disabled selected>Select Category</option>
    </select>
</div>

<div class="container-fluid px-4 my-5">
    @if (User.IsInRole("Admin"))
    {
        
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div>
                <h4 class="fw-bold text-dark mb-1">Product Catalog</h4>
                <p class="text-muted small mb-0">Manage your store products, update pricing, and descriptions.</p>
            </div>
                
            <a asp-action="Create" class="btn btn-primary rounded-3 px-4 py-2 d-flex align-items-center gap-2 shadow-sm fw-medium">
                <i class="bi bi-plus-circle-fill"></i> Add New Product
            </a>
        </div>
    </div>
    }

    <div id="tableBody" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card bg-white d-flex flex-column">

                    <div class="position-relative overflow-hidden bg-light img-container">
                        @if (!string.IsNullOrEmpty(item.ImageURL))
                        {
                            <img src="@item.ImageURL" class="card-img-top object-fit-cover w-100" style="height: 220px;" alt="@item.Title">
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-secondary-subtle text-muted" style="height: 220px;">
                                <i class="bi bi-image display-6"></i>
                            </div>
                        }
                        <span class="position-absolute top-0 start-0 bg-dark text-white fs-7 px-2 py-1 rounded-bottom-end m-2 shadow-sm small">Product</span>
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <h6 class="card-title fw-bold text-dark text-truncate mb-2" title="@item.Title">
                            @item.Title
                        </h6>

                        <p class="text-muted small text-truncate-2 mb-3" style="height: 40px; font-size: 0.85rem;">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-light-subtle">
                            <div>
                                <span class="fs-5 fw-bold text-primary">$@item.Price</span>
                            </div>

                            <div class="d-flex gap-1 actions-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm rounded-2 p-2 border-light-subtle" title="Edit">
                                    <i class="bi bi-pencil-square text-primary fs-6"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm rounded-2 p-2 border-light-subtle" title="Details">
                                    <i class="bi bi-eye text-success fs-6"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm rounded-2 p-2 border-light-subtle" title="Delete">
                                    <i class="bi bi-trash3 text-danger fs-6"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Modal title</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a class="btn btn-danger" id="delete-save-btn">Save changes</a>
            </div>
        </div>
    </div>
</div>

<style>
    .product-card {
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
        }

    .img-container img {
        transition: transform 0.4s ease;
    }

    .product-card:hover .img-container img {
        transform: scale(1.04);
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .fs-7 {
        font-size: 0.75rem;
    }

    .rounded-bottom-end {
        border-bottom-right-radius: 8px;
    }

    .actions-group .btn:hover {
        background-color: #f8f9fa;
        border-color: #cbd5e1 !important;
    }
</style>



<script>

    let deleteButtons = document.querySelectorAll('.delete-btn');
    deleteButtons.forEach(button => {
        button.addEventListener('click', function () {
            let productId = this.getAttribute('data-id');
            let modalBody = document.querySelector('.modal-body');
            let deleteSaveBtn = document.querySelector('#delete-save-btn');
            modalBody.innerHTML = `Are you sure you want to delete product this Product`;
            deleteSaveBtn.setAttribute('href', `/Product/Delete/${productId}`);
        });
    });
    
    let CategoryId = document.querySelector('#Category');
    let tableBody = document.querySelector('#tableBody');
    let ClearFilter = document.querySelector('#ClearFilter');
    CategoryId.addEventListener('change' , ()=>{


        getProductsByCat(CategoryId.value);
        
    })
    ClearFilter.addEventListener('click' , ()=>{

        Clear();

        
    })

    async function getProductsByCat(CategoryId) {
        const response = await fetch(`/Product/GetProductByCategory/${CategoryId}`, {
            method: 'GET',
        });

        if (response.ok) {
            const data = await response.text();
            console.log(data);

            tableBody.innerHTML =  data;
        }
    }

    async function Clear() {
        CategoryId.selectedIndex = 0;
        const response = await fetch(`/Product/GetProductByCategory`, {
            method: 'GET',
        });

        if (response.ok) {
            const data = await response.text();
            tableBody.innerHTML =  data;
        }
    }


</script>